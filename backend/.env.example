# Copy this file to .env and adjust as needed. No values are required to run Milestone 1 —
# embeddings and syntax validation run fully locally.

# --- App ---
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Uploads / submission limits ---
MAX_UPLOAD_SIZE_BYTES=1048576
ALLOWED_EXTENSIONS=.py,.java

# --- Code execution (EXPERIMENTAL, off by default) ---
# Read docs/code-execution-safety.md before enabling this, especially before any public
# deployment. Runs submitted code directly on this server with a timeout and output cap —
# it is NOT a full sandbox (no network isolation, no container boundary).
ENABLE_CODE_EXECUTION=false
EXECUTION_TIMEOUT_SECONDS=5
EXECUTION_MAX_OUTPUT_CHARS=4000

# --- RAG / vector store ---
VECTOR_STORE_DIR=./data/vector_store
VECTOR_STORE_COLLECTION=secure_coding_kb
EMBEDDING_MODEL=all-MiniLM-L6-v2
CHUNK_SIZE_TOKENS=300
CHUNK_OVERLAP_TOKENS=50

# --- Reserved for later milestones (agent reasoning), not used in Milestone 1 ---
# LLM_PROVIDER=anthropic
# LLM_API_KEY=
# LLM_MODEL=claude-sonnet-5
